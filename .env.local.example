# ============================================================
# Silvana López — Terapia Online
# Environment Variables
# ============================================================
# Copy this to .env.local and fill in the values
# NEVER commit .env.local to git
# ============================================================

# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000/admin

# Production values:
# NEXT_PUBLIC_APP_URL=https://silvanalopez.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.silvanalopez.com

# ─── Supabase ──────────────────────────────────────────────
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── PayPal ────────────────────────────────────────────────
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AX...
PAYPAL_CLIENT_SECRET=EL...
PAYPAL_WEBHOOK_ID=WH-...
# Use 'sandbox' for dev, 'live' for production
PAYPAL_MODE=sandbox

# ─── Google Calendar + Meet (OAuth) ────────────────────────
# OAuth 2.0 Client credentials — https://console.cloud.google.com/apis/credentials
# 1. Enable "Google Calendar API" in Google Cloud Console
# 2. Configure Google Auth Platform (External, add yourself as test user)
# 3. Add scopes: userinfo.email, calendar, calendar.events
# 4. Create Credentials → OAuth Client ID → Web application
# 5. Authorized redirect URI: http://localhost:3000/api/google/callback
# 6. Copy Client ID / Secret here; tokens persist in google_integrations table
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Production override (update redirect URI in Google Cloud Console too):
# GOOGLE_REDIRECT_URI=https://admin.silvanalopez.com/api/google/callback

# ─── SMTP (Email) ─────────────────────────────────────────
# Cualquier proveedor SMTP funciona (Brevo, Mailgun, SES, Zoho, Postmark...).
# Brevo: https://app.brevo.com/settings/keys/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=login@smtp-brevo.com
SMTP_PASSWORD=xxxxxxxx
# TRUE si usas puerto 465 (SSL directo); FALSE para 587 (STARTTLS)
SMTP_SECURE=false
EMAIL_FROM=Silvana López <noreply@silvanalopez.com>

# ─── Security ─────────────────────────────────────────────
# Used for TOTP 2FA encryption
TWO_FACTOR_ENCRYPTION_KEY=generate-a-32-char-random-string
