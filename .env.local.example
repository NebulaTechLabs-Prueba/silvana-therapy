# ============================================================
# Silvana López — Terapia Online
# Environment Variables
# ============================================================
# Copy this to .env.local and fill in the values
# NEVER commit .env.local to git
# ============================================================

# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000/admin

# Production values:
# NEXT_PUBLIC_APP_URL=https://silvanalopez.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.silvanalopez.com

# ─── Supabase ──────────────────────────────────────────────
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── PayPal ────────────────────────────────────────────────
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AX...
PAYPAL_CLIENT_SECRET=EL...
PAYPAL_WEBHOOK_ID=WH-...
# Use 'sandbox' for dev, 'live' for production
PAYPAL_MODE=sandbox

# ─── Google Calendar ───────────────────────────────────────
# Service Account JSON (base64 encoded)
# 1. Create service account in Google Cloud Console
# 2. Download JSON key
# 3. Base64 encode: cat key.json | base64 -w 0
# 4. Share your Google Calendar with the service account email
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=eyJ...
GOOGLE_CALENDAR_ID=silvana@gmail.com

# ─── Resend (Email) ───────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=Silvana López <noreply@silvanalopez.com>

# ─── Security ─────────────────────────────────────────────
# Used for TOTP 2FA encryption
TWO_FACTOR_ENCRYPTION_KEY=generate-a-32-char-random-string
